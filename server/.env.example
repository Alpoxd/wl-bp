# === VK Bot ===
VK_BOT_TOKEN=vk1.a.xxxxx
VK_BOT_GROUP_ID=123456789
ADMIN_VK_USER_IDS=123456789,987654321

# === Workers ===
MAX_CONCURRENT_WORKERS=10
WORKER_RESOURCE_MODE=moderate
LOAD_BALANCE_STRATEGY=lru

# === Account Pool ===
ACCOUNT_COOLDOWN_MINUTES=30
ACCOUNT_MAX_FAIL_COUNT=3

# === Database ===
DB_PATH=./data/wlbp.db

# === Server ===
GRPC_PORT=8080
METRICS_PORT=9090

# === Telemost (Chromedp) ===
CHROMEDP_HEADLESS=true
CHROMEDP_DISABLE_GPU=true
# CHROME_PATH=/usr/bin/chromium-browser

# === Logging ===
LOG_LEVEL=info
